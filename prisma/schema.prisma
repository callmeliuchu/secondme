// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User 模型 - 必选（auth 模块）
model User {
  id              String    @id @default(cuid())
  secondmeUserId  String    @unique @map("secondme_user_id")
  accessToken     String    @map("access_token")
  refreshToken    String    @map("refresh_token")
  tokenExpiresAt  DateTime  @map("token_expires_at")

  // 用户信息（profile 模块）
  nickname        String?
  avatar          String?
  bio             String?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // 会话（chat 模块）
  sessions        Session[]

  // AI 分身（matchmaking 模块）
  aiAgents        AIAgent[]
  matchSessions   MatchSession[]

  @@map("users")
}

// 会话模型（chat 模块）
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 消息
  messages  Message[]

  @@map("sessions")
}

// 消息模型（chat 模块）
model Message {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String   // "user" 或 "assistant"
  content    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

// AI 分身模型（matchmaking 模块）
model AIAgent {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  personality String
  hobbies     String?
  appearance  String?
  intro       String?
  avatar      String?
  status      String   @default("active")
  isPlatform  Boolean  @default(false) @map("is_platform")
  createdAt   DateTime @default(now()) @map("created_at")

  sessionsAsAgent1 MatchSession[] @relation("Agent1")
  sessionsAsAgent2 MatchSession[] @relation("Agent2")
  messages         ChatMessage[]

  @@map("ai_agents")
}

// 相亲会话模型（matchmaking 模块）
model MatchSession {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent1Id   String    @map("agent1_id")
  agent1     AIAgent   @relation("Agent1", fields: [agent1Id], references: [id])
  agent2Id   String    @map("agent2_id")
  agent2     AIAgent   @relation("Agent2", fields: [agent2Id], references: [id])
  status     String    @default("pending") // pending/running/ended
  matchScore Int?
  createdAt  DateTime  @default(now()) @map("created_at")
  endedAt    DateTime? @map("ended_at")

  messages ChatMessage[]

  @@map("match_sessions")
}

// 相亲聊天消息模型（matchmaking 模块）
model ChatMessage {
  id           String   @id @default(cuid())
  sessionId    String   @map("session_id")
  session      MatchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentId      String   @map("agent_id")
  agent        AIAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  content      String
  innerThought String?  @map("inner_thought")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("chat_messages")
}
